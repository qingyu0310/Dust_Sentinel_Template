{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
            "serverpath": "C:/Program Files/Path/openocd/bin/openocd.exe",
            "gdbPath": "D:/Zephyr/zephyr-sdk-0.16.8/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb.exe",
            "runToEntryPoint": "main",
            "configFiles": [
                "${workspaceFolder}/projects/boards/st/puzhong/openocd.cfg"
            ],
            "searchDir": [
                "C:/Program Files/Path/openocd/share/openocd/scripts"
            ]
        },
        {
            "name": "Debug HPM5361ICB",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
            "serverpath": "D:/Zephyr_HPMicro/sdk_env/tools/openocd_backup/openocd.exe",
            "gdbPath": "D:/Zephyr/zephyr-sdk-0.16.8/riscv64-zephyr-elf/bin/riscv64-zephyr-elf-gdb.exe",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "configFiles": [
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd/probes/cmsis_dap.cfg",
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd/soc/hpm5300.cfg",
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd/boards/hpm5300evk.cfg"
            ],
            "searchDir": [
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 500",
                "gdb_memory_map disable"
            ],
            "overrideLaunchCommands": [
                "set remotetimeout 20",
                "target extended-remote localhost:50000",
                "set mem inaccessible-by-default off",
                "mem 0x80000000 0x80100000 ro 32 nocache",
                "mem 0x00080000 0x000a0000 rw 32 nocache",
                "set remote hardware-breakpoint-limit 4",
                "set breakpoint auto-hw on",
                "monitor reset halt",
                "thbreak main",
                "continue"
            ]
        },
        {
            "name": "Attach HPM5361ICB",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
            "serverpath": "D:/Zephyr_HPMicro/sdk_env/tools/openocd_backup/openocd.exe",
            "gdbPath": "D:/Zephyr/zephyr-sdk-0.16.8/riscv64-zephyr-elf/bin/riscv64-zephyr-elf-gdb.exe",
            "showDevDebugOutput": "none",
            "configFiles": [
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd/probes/cmsis_dap.cfg",
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd/soc/hpm5300.cfg",
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd/boards/hpm5300evk.cfg"
            ],
            "searchDir": [
                "D:/Zephyr_HPMicro/sdk_env/hpm_sdk/boards/openocd"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 500",
                "gdb_memory_map disable"
            ],
            "overrideAttachCommands": [
                "set remotetimeout 20",
                "target extended-remote localhost:50000",
                "set mem inaccessible-by-default off",
                "mem 0x80000000 0x80100000 ro 32 nocache",
                "mem 0x00080000 0x000a0000 rw 32 nocache",
                "set remote hardware-breakpoint-limit 4",
                "set breakpoint auto-hw on",
                "monitor halt"
            ]
        },
    ]
}
